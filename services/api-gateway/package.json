{
	"name": "api-gateway",
	"version": "1.0.0",
	"description": "Base framework for all tlp microservices",
	"main": "app.ts",
	"type": "module",
	"scripts": {
		"dev": "NODE_ENV=development NODE_PATH=./src nodemon --exec 'ts-node-esm' src/app.ts",
		"build": "tsc && cp -R config/ ./dist && cp -R src/public/ ./dist",
		"format": "prettier --write .",
		"lint:fix": "npm run lint:fix:eslint && npm run lint:fix:prettier",
		"lint:eslint": "eslint --cache \"src/**/*.{js,ts}\"",
		"lint:prettier": "prettier --check \"src/**/*.{js,ts}\"",
		"lint:fix:eslint": "npm run lint:eslint -- --fix",
		"lint:fix:prettier": "prettier --write \"src/**/*.{js,ts}\"",
		"pre-commit": "lint-staged --no-stash",
		"test": "echo \"Error: no test specified\" && exit 1"
	},
	"lint-staged": {
		"*.{js,ts,json}": [
			"pnpm run lint:fix"
		]
	},
	"author": "",
	"license": "ISC",
	"dependencies": {
		"@eslint/compat": "^1.3.2",
		"@eslint/js": "^9.35.0",
		"axios": "^1.11.0",
		"ejs": "^3.1.10",
		"eslint": "^9.35.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.12.2",
		"express": "^4.18.2",
		"globals": "^16.3.0",
		"helmet": "^8.1.0",
		"http-proxy-middleware": "^2.0.6",
		"js-yaml": "^4.1.0",
		"jsonwebtoken": "^9.0.2",
		"lint-staged": "^16.1.6",
		"mongoose": "^8.18.0",
		"morgan": "^1.10.1",
		"prettier": "^3.6.2",
		"prettier-plugin-svelte": "^3.4.0",
		"typescript-eslint": "^8.42.0"
	},
	"devDependencies": {
		"@types/express": "^4.17.17",
		"@types/js-yaml": "^4.0.9",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/morgan": "^1.9.10",
		"@types/node": "^24.3.1",
		"dotenv": "^17.2.2",
		"eslint": "^8.34.0",
		"nodemon": "^3.1.10",
		"ts-node": "^10.9.2",
		"tsconfig-paths": "^4.2.0",
		"typescript": "^5.9.2"
	}
}
