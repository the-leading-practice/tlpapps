{
  "name": "api-gateway",
  "version": "1.0.0",
  "description": "Base framework for all tlp microservices",
  "main": "app.ts",
  "scripts": {
    "dev": "NODE_ENV=development NODE_PATH=./src nodemon --exec 'ts-node-esm' src/app.ts",
    "build": "tsc && cp -R config/ ./dist && cp .env ./dist && cp -R src/public/ ./dist",
    "lint": "eslint --ext .ts src",
    "lint:fix": "eslint -ext .ts src --fix",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.4.0",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "helmet": "^7.0.0",
    "http-proxy-middleware": "^2.0.6",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^7.0.2",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/js-yaml": "^4.0.5",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/morgan": "^1.9.4",
    "@types/node": "^18.14.1",
    "dotenv": "^16.0.3",
    "eslint": "^8.34.0",
    "nodemon": "^2.0.20",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.1.2",
    "typescript": "^4.9.5"
  }
}
