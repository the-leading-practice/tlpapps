{
	"name": "@tlpapps/monitor",
	"version": "1.0.0",
	"description": "GHL monitor service",
	"main": "app.ts",
	"type": "module",
	"scripts": {
		"dev": "NODE_PATH=./src nodemon --exec 'npx tsx' src/app.ts",
		"build": "tsc && cp -R config/ ./dist",
		"format": "prettier --write .",
		"lint:fix": "npm run lint:fix:eslint && npm run lint:fix:prettier",
		"lint:eslint": "eslint --cache \"src/**/*.{js,ts}\"",
		"lint:prettier": "prettier --check \"src/**/*.{js,ts}\"",
		"lint:fix:eslint": "npm run lint:eslint -- --fix",
		"lint:fix:prettier": "prettier --write \"src/**/*.{js,ts}\"",
		"pre-commit": "lint-staged --no-stash",
		"test": "echo \"Error: no test specified\" && exit 1"
	},
	"lint-staged": {
		"*.{js,ts,json}": [
			"pnpm run lint:fix"
		]
	},
	"author": "",
	"license": "ISC",
	"dependencies": {
		"@eslint/compat": "^1.3.2",
		"@eslint/js": "^9.35.0",
		"@types/cors": "^2.8.19",
		"cors": "^2.8.5",
		"eslint": "^9.35.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.12.2",
		"express": "^5.1.0",
		"globals": "^16.3.0",
		"js-yaml": "^4.1.0",
		"lint-staged": "^16.1.6",
		"prettier": "^3.6.2",
		"prettier-plugin-svelte": "^3.4.0",
		"tsx": "^4.20.5",
		"typescript-eslint": "^8.42.0"
	},
	"devDependencies": {
		"@types/express": "^5.0.3",
		"@types/js-yaml": "^4.0.9",
		"@types/node": "^24.3.1",
		"dotenv": "^17.2.2",
		"eslint": "^8.34.0",
		"nodemon": "^3.1.10",
		"ts-node": "^10.9.2",
		"tsconfig-paths": "^4.2.0",
		"typescript": "^5.9.2"
	}
}
