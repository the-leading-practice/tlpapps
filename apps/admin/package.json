{
	"name": "admin",
	"version": "0.0.1",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"test": "playwright test",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test:unit": "vitest",
		"lint": "prettier --plugin-search-dir . --check . && eslint .",
		"format": "prettier --plugin-search-dir . --write .",
		"storybook": "node scripts/storybook-prep.mjs && storybook dev -p 6006",
		"storybook:build": "node scripts/storybook-prep.mjs && storybook build -o storybook-static",
		"docs-sync": "echo 'frontend: docs/components.md is the source of truth; rebuild storybook static for hosting'"
	},
	"devDependencies": {
		"@fontsource/fira-mono": "^4.5.10",
		"@storybook/addon-essentials": "^8.6.18",
		"@storybook/addon-svelte-csf": "^4.2.0",
		"@storybook/svelte": "^8.6.18",
		"@storybook/sveltekit": "^8.6.18",
		"@iconify/svelte": "^3.1.6",
		"storybook": "^8.6.18",
		"@neoconfetti/svelte": "^1.0.0",
		"@playwright/test": "^1.28.1",
		"@sveltejs/adapter-node": "^1.3.0",
		"@sveltejs/kit": "^1.20.4",
		"@sveltejs/vite-plugin-svelte": "^2.4.2",
		"@types/cookie": "^0.5.1",
		"@typescript-eslint/eslint-plugin": "^5.45.0",
		"@typescript-eslint/parser": "^5.45.0",
		"autoprefixer": "^10.4.14",
		"daisyui": "^3.9.3",
		"eslint": "^8.28.0",
		"eslint-config-prettier": "^8.5.0",
		"eslint-plugin-svelte": "^2.30.0",
		"highlight.js": "^11.8.0",
		"postcss": "^8.4.24",
		"postcss-load-config": "^4.0.1",
		"prettier": "^2.8.0",
		"prettier-plugin-svelte": "^2.10.1",
		"svelte": "^4.0.0",
		"svelte-check": "^3.4.3",
		"tailwindcss": "^3.3.2",
		"tslib": "^2.4.1",
		"typescript": "~5.4.5",
		"vite": "^4.3.6",
		"vitest": "^0.25.3"
	},
	"type": "module",
	"dependencies": {
		"@codemirror/commands": "^6.2.4",
		"@codemirror/lang-sql": "^6.5.2",
		"@codemirror/theme-one-dark": "^6.1.2",
		"@codemirror/view": "^6.14.0",
		"@popperjs/core": "^2.11.8",
		"@supabase/supabase-js": "^2.43.4",
		"@tailwindcss/typography": "^0.5.10",
		"prismjs": "^1.29.0",
		"svelte-codemirror-editor": "^1.1.0",
		"svelte-heros-v2": "^0.7.3",
		"tailwind-merge": "^1.13.2",
		"thememirror": "^2.0.1"
	}
}
