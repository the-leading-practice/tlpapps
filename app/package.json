{
  "name": "@tlpapps/server",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "node --import tsx --test",
    "db:generate": "cd src/db/pg && node --import tsx ../../../node_modules/drizzle-kit/bin.cjs generate",
    "migrate": "tsx scripts/migrate.ts",
    "backfill:config": "tsx scripts/backfill-config.ts",
    "diff:config": "tsx scripts/diff-config.ts",
    "reconcile:patients": "tsx scripts/reconcile-patients.ts"
  },
  "dependencies": {
    "@gohighlevel/api-client": "^1.0.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "croner": "^8.0.0",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.36.4",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^7.2.0",
    "morgan": "^1.10.0",
    "node-telegram-bot-api": "^0.64.0",
    "pino": "^8.16.0",
    "pino-pretty": "^10.2.0",
    "postgres": "^3.4.5",
    "tsx": "^4.0.0",
    "ws": "^8.14.0"
  },
  "devDependencies": {
    "drizzle-kit": "^0.28.1",
    "@types/compression": "^1.7.0",
    "@types/cors": "^2.8.0",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/morgan": "^1.9.0",
    "@types/node": "^20.0.0",
    "@types/node-telegram-bot-api": "^0.64.0",
    "@types/ws": "^8.5.0",
    "typescript": "^5.3.0"
  }
}
