# Server
PORT=8080
LOG_LEVEL=info

# MongoDB
MONGO_CONN_STRING=mongodb://%USER%:%PW%@localhost:27017
MONGO_USER=
MONGO_PASS=
MONGO_DB=tlpapps

# Postgres (Drizzle)
DATABASE_URL=postgres://user:pass@localhost:5432/tlpapps
# Set to "true" only on the one-shot migration job, never on serving replicas
RUN_MIGRATIONS=false

# Config module migration (P03)
# Which store the config module reads/writes as primary: mongo | pg. Default mongo.
CONFIG_PRIMARY=mongo
# After flipping CONFIG_PRIMARY=pg, mirror config writes back to Mongo as a warm
# standby for the 14-day rollback window. Set "off" to stop legacy writes after soak.
CONFIG_LEGACY_WRITE=on

# Patients dual-write (P04)
# When "on", patient mutations mirror Mongo -> Postgres (shadow). Mongo stays primary;
# PG failures log + count but never fail the request. Default off => behavior-neutral.
PG_DUAL_WRITE_PATIENTS=off

# Sync engine (P07 schema; engine wired in P08)
# Gates whether this replica runs the cron-driven DrChrono<->GHL sync loop. Exactly
# one replica wins leader election (pg advisory lock); others idle. Default off.
RUN_CRON=off
# First key of the two-arg pg_try_advisory_lock(base, hashtext(kind)) used for cron
# leader election — namespaces this app's locks on the shared PG instance.
SYNC_LEADER_KEY_BASE=910700
# Sync write direction kill switches (P08 engine computes intent; P09 wires real
# EHR API writers). Values: off | dry | on.
#   off = skip writes + count; dry = log intent, NO API call; on = real EHR write.
# DEFAULT dry => fully read-only. Flipping to `on` is a HARD per-direction human gate
# (P09 T06) — do NOT set `on` without the recorded cutover sign-off.
SYNC_WRITE_DRCHRONO_TO_GHL=dry
SYNC_WRITE_GHL_TO_DRCHRONO=dry

# Webhook authentication secrets (gateway/Coolify-injected; never commit real values).
# GHL signs each webhook with HMAC-SHA256 over the raw body (x-wh-signature header).
GHL_WEBHOOK_SECRET=
# DrChrono sends a plaintext secret_token in the webhook body.
DRCHRONO_WEBHOOK_SECRET=

# JWT / Encryption
TOKEN_KEY=

# GHL (GoHighLevel)
CLIENT_ID=
CLIENT_SECRET=
REDIRECT_URL=https://tlpapps.theleadingpractice.com:8080/oauth
GHL_API_URL=https://services.leadconnectorhq.com
GHL_API_VERSION=2021-07-28

# DrChrono
DRCHRONO_API=https://drchrono.com
OAUTH_REDIRECT_URI=https://tlpapps.theleadingpractice.com:8080/oauth/callback

# Telegram Notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ClickUp Notifications
CLICKUP_API_KEY=
CLICKUP_CHAT_ID=

# Notification routing (telegram or clickup)
MSG_SERVICE=clickup
