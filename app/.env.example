# Server
PORT=8080
LOG_LEVEL=info

# MongoDB
MONGO_CONN_STRING=mongodb://%USER%:%PW%@localhost:27017
MONGO_USER=
MONGO_PASS=
MONGO_DB=tlpapps

# Postgres (Drizzle)
DATABASE_URL=postgres://user:pass@localhost:5432/tlpapps
# Set to "true" only on the one-shot migration job, never on serving replicas
RUN_MIGRATIONS=false

# JWT / Encryption
TOKEN_KEY=

# GHL (GoHighLevel)
CLIENT_ID=
CLIENT_SECRET=
REDIRECT_URL=https://tlpapps.theleadingpractice.com:8080/oauth
GHL_API_URL=https://services.leadconnectorhq.com
GHL_API_VERSION=2021-07-28

# DrChrono
DRCHRONO_API=https://drchrono.com
OAUTH_REDIRECT_URI=https://tlpapps.theleadingpractice.com:8080/oauth/callback

# Telegram Notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ClickUp Notifications
CLICKUP_API_KEY=
CLICKUP_CHAT_ID=

# Notification routing (telegram or clickup)
MSG_SERVICE=clickup
